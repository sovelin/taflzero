{
  "name": "zevratafl",
  "version": "0.0.1",
  "description": "Zevratafl engine for Hnefatafl game (Copenhagen variant initially)",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:classic": "tsup",
    "build": "tsup --config tsup.config.lib.ts",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "lint": "echo 'No lint step configured'",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "run:inspect": "node --inspect --enable-source-maps dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@vitest/ui": "3.2.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "tsx": "^4.20.6"
  }
}
